Servo radarServo;

// Pin assignments
#define TRIG 2
#define ECHO 3
#define ALARM_PIN 4        
#define RGB_R 5
#define RGB_G 6
#define RGB_B 7
#define PASSIVE_BUZZER 8   
#define SERVO_PIN 9
#define TOUCH 10


int angle = 70; // Start comfortably in the middle. Helps to not scan the insides of the book.
int direction = 1;
int score = 0; // Mode tracker: 0=Normal, 1=Fast, 2=Still.        
bool systemActive = false;

unsigned long lastAlarm = 0;
unsigned long previousMillisServo = 0;
unsigned long previousMillisPing = 0; // This timer made my Ultrasonic Sensor useful again.

bool buttonPressed = false;
unsigned long pressStartTime = 0;

void setup() {
  // Opens the communication line to the computer
  Serial.begin(9600); 

  // Sets up the ins and outs
  pinMode(TRIG, OUTPUT);
  pinMode(ECHO, INPUT);
  pinMode(ALARM_PIN, OUTPUT);
  pinMode(TOUCH, INPUT);
  
  pinMode(RGB_R, OUTPUT);
  pinMode(RGB_G, OUTPUT);
  pinMode(RGB_B, OUTPUT);
  
  pinMode(PASSIVE_BUZZER, OUTPUT);

  // Plays the waking-up song
  introMelody();
  
  // Turns the LED white so the user knows the code is ready
  setRGB(255, 255, 255); 
  
  // If someone is already holding the button when it turns on, the code "waits" for them to let go
  while(digitalRead(TOUCH) == HIGH) { delay(10); }

  // Stares intensely at the touch sensor until someone presses it
  while (digitalRead(TOUCH) == LOW) {
    delay(10);
  }

  startSystem();
}

void loop() {
  if (!systemActive) {
    setRGB(0, 0, 0); // Lights out
    
    // Did somebody touch me?
    if (digitalRead(TOUCH) == HIGH) {
      delay(50); // Give the button a moment to stop bouncing
      while(digitalRead(TOUCH) == HIGH); // Wait for the user to remove their finger
      startSystem(); // Rise and shine!
    }
    return; // Don't do any radar stuff while inactive
  }

  // 1. Figure out if the user is tapping or holding the button
  checkTouch();      
  
  // 2. Make the LED match our current score (mode)
  setModeColor();    

  unsigned long currentMillis = millis();

  // 3. Move the servo back and forth (unless we are in mode 2, then stand very still)
  if (score != 2) {
    int speedDelay = getSpeed(); // How much coffee did we drink?
    
    if (currentMillis - previousMillisServo >= speedDelay) {
      previousMillisServo = currentMillis;
      radarServo.write(angle);
      
      angle += direction;
      if (angle >= 90) {   
        angle = 90;
        direction = -1;
      }
      if (angle <= 15) {
        angle = 15;
        direction = 1;
      }
    }
  }

  // 4. MEASURE DISTANCE & ALARM
  // Oh look, a timer. Because apparently asking the ultrasonic sensor for the distance 
  // 10,000 times a second causes it to have an existential crisis, drown in its own echoes, 
  // and spit out garbage data like "0". Who could have possibly predicted that? 
  // Now I graciously grant it 50 whole milliseconds to think about its life choices 
  // before I yell at it again. You're welcome, sensor.
  // Not my proudest moment... 
  if (currentMillis - previousMillisPing >= 50) {
    previousMillisPing = currentMillis;
    
    long distance = getDistance();
    
    // 5. Sends the findings to the computer over the serial cable
    Serial.print(angle);
    Serial.print(",");
    Serial.print(distance);
    Serial.print(",");
    Serial.print(score);
    Serial.print(".");
    Serial.println(); 

    // 6. If something is suspiciously close, PANIC!
    if (distance >= 5 && distance <= 60) {
      triggerAlarm();
    }
  }
}

// ----------------------------------------------------

void startSystem() {
  // Grab the motor and yank it to the center
  radarServo.attach(SERVO_PIN);
  radarServo.write(70); 
  
  // Visual and audio confirmation that the code is alive
  setRGB(0, 0, 0); 
  introMelody();
  delay(200);
      
  systemActive = true;
  score = 0; // Default to normal speed
}

void checkTouch() {
  bool currentTouch = (digitalRead(TOUCH) == HIGH);
  
  // The exact moment the finger makes contact
  if (currentTouch && !buttonPressed) {
    buttonPressed = true;
    pressStartTime = millis();
  }
  
  // They are still holding it...
  if (currentTouch && buttonPressed) {
    // If they hold it for 3 seconds --> Shut it down.
    if (millis() - pressStartTime > 3000) {
      shutdownMelody();
      systemActive = false;
      buttonPressed = false; 
      while(digitalRead(TOUCH) == HIGH);
      return;
    }
  }
  
  // Lettigng go of the button.
  if (!currentTouch && buttonPressed) {
    buttonPressed = false;
    long pressDuration = millis() - pressStartTime;
    
    // If it was a quick tap, change the mode
    if (pressDuration < 3000 && systemActive) {
      score++;
      if (score > 2) score = 0; // Loop back to mode 0
      tone(PASSIVE_BUZZER, 2000, 100); // Happy little beep
    }
  }
}

void setModeColor() {
  // Paint with light
  if (score == 0) setRGB(0, 255, 0);        // Green means normal
  else if (score == 1) setRGB(0, 0, 255);   // Blue means fast
  else if (score == 2) setRGB(255, 255, 0); // Yellow means frozen
}

void setRGB(int r, int g, int b) {
  analogWrite(RGB_R, r);
  analogWrite(RGB_G, g);
  analogWrite(RGB_B, b);
}

int getSpeed() {
  if (score == 0) return 30; 
  if (score == 1) return 10; 
  return 1000;
}

long getDistance() {
  digitalWrite(TRIG, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG, LOW);

  long duration = pulseIn(ECHO, HIGH, 30000);
  
  if (duration == 0) return 400; 

  // Math! Convert time into centimeters based on the speed of sound.
  long dist = duration * 0.034 / 2;
  if (dist > 400) dist = 400; 
  return dist;
}

void triggerAlarm() {
  // Blinks the red LED and beeps loudly, but don't do it faster than every 250ms (got annoying while testing)
  if (millis() - lastAlarm > 250) { 
    digitalWrite(ALARM_PIN, HIGH); 
    delay(50);                    
    digitalWrite(ALARM_PIN, LOW);  
    lastAlarm = millis();
  }
}

void introMelody() {
  // Rising notes to feel more optimistic
  int melody[] = {262, 330, 392, 523};
  for (int i = 0; i < 4; i++) {
    tone(PASSIVE_BUZZER, melody[i], 200);
    delay(150);
  }
  noTone(PASSIVE_BUZZER);
}

void shutdownMelody() {
  int melody[] = {523, 392, 330, 262}; 
  for (int i = 0; i < 4; i++) {
    tone(PASSIVE_BUZZER, melody[i], 200);
    delay(150);
  }
  noTone(PASSIVE_BUZZER);
}
